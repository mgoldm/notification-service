# See https://help.github.com/articles/ignoring-files for more about ignoring files.

/.bundle
/vendor/bundle
/vendor/cache

/.env
/config/database.yml
/config/secrets.yml

/log/*
/tmp/*
!/log/.keep
!/tmp/.keep

/tmp/pids/*
!/tmp/pids/
!/tmp/pids/.keep

/storage/*
!/storage/.keep
/tmp/storage/*
!/tmp/storage/
!/tmp/storage/.keep

/config/master.key
